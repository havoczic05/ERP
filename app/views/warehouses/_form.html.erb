<%= turbo_frame_tag dom_id(warehouse) do %>
  <%= form_with model: warehouse, local: false do |f| %>
    <% if warehouse.errors.any? %>
      <div id="error_explanation">
        <h2>No se pudo guardar el almacén. Corrija los siguientes errores:</h2>
        <ul>
          <% warehouse.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="field-grid">
      <div class="field">
        <%= f.label :name, 'Nombre' %>
        <%= f.text_field :name %>
        <% if warehouse.errors[:name].any? %>
          <span class="error"><%= warehouse.errors[:name].join(', ') %></span>
        <% end %>
      </div>

      <div class="field">
        <%= f.label :location, 'Ubicación' %>
        <%= f.text_field :location %>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit(warehouse.new_record? ? 'Crear almacén' : 'Actualizar almacén') %>
    </div>
  <% end %>
<% end %>
