<div class="page-head page-head--with-action">
  <div>
    <h1>Almacenes</h1>
    <p class="page-sub">Ubicaciones donde se almacena el inventario.</p>
  </div>
  <%= action_link 'Nuevo almacén', new_warehouse_path, variant: :primary, size: :md, icon: :plus,
                  class: "fab", aria: { label: "Nuevo almacén" },
                  data: { turbo_frame: 'modal', controller: 'fab', action: 'fab#click' } %>
</div>

<%= render "shared/settings_nav" %>

<div class="table-scroll">
<table class="table-cards">
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Ubicación</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody id="warehouses">
    <%= render @warehouses %>
  </tbody>
</table>
</div>

<% if @warehouses.empty? %>
  <p id="no-warehouses-message">No se encontraron almacenes.</p>
<% end %>

<%= pagination_nav(@pagy) %>

<%= render "shared/modal_frame" %>
