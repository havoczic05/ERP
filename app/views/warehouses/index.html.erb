<div class="page-head"><h1>Almacenes</h1></div>

<div class="toolbar">
  <%= action_link 'Nuevo almacén', new_warehouse_path, variant: :primary, size: :md, icon: :plus,
                  data: { turbo_frame: 'modal' } %>
</div>

<table>
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Ubicación</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody id="warehouses">
    <%= render @warehouses %>
  </tbody>
</table>

<% if @warehouses.empty? %>
  <p id="no-warehouses-message">No se encontraron almacenes.</p>
<% end %>

<%= pagination_nav(@pagy) %>

<%= render "shared/modal_frame" %>
