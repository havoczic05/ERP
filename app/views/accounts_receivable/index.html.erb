<div class="page-head"><h1>Cuentas por Cobrar</h1></div>

<div class="toolbar">
  <%= form_with url: accounts_receivable_path, method: :get, class: "filters" do |f| %>
    <%= search_field placeholder: 'Cliente o correlativo' %>
    <div class="field">
      <%= label_tag :status, 'Estado' %>
      <%= select_tag :status,
            options_for_select([ [ 'Todos', '' ], [ 'Pendiente', 'pendiente' ], [ 'Vencida', 'vencida' ] ],
                               params[:status]) %>
    </div>
    <div class="field">
      <%= label_tag :due_within, 'Vence en' %>
      <%= select_tag :due_within, options_for_select(DateRange::DUE_OPTIONS, params[:due_within]) %>
    </div>
    <div class="field">
      <%= label_tag :date_range, 'Vencimiento' %>
      <%= select_tag :date_range, options_for_select(DateRange::OPTIONS, params[:date_range]) %>
    </div>
    <div class="field">
      <%= label_tag :on, 'Día específico' %>
      <%= date_field_tag :on, params[:on] %>
    </div>
    <%= submit_button f, 'Buscar' %>
    <%= clear_filters_link accounts_receivable_path %>
  <% end %>
</div>

<table>
  <thead>
    <tr>
      <th>Cliente</th>
      <th>Venta</th>
      <th>N° de cuota</th>
      <th>C. Vencidas</th>
      <th>Cuota actual (USD)</th>
      <th>Saldo total (USD)</th>
      <th>Vencimiento</th>
      <th>Estado</th>
      <th>Pago</th>
    </tr>
  </thead>
  <tbody>
    <% @installments.each do |installment| %>
      <tr id="<%= dom_id(installment) %>">
        <td><%= installment.sale.client.full_name %></td>
        <td><%= link_to installment.sale.correlative, sale_path(installment.sale) %></td>
        <td><%= "#{installment.installment_number}/#{@installment_totals[installment.sale_id]}" %></td>
        <td><%= @overdue_counts[installment.sale_id] || 0 %></td>
        <td><%= money(installment.amount_usd) %></td>
        <td><%= money(@sale_balances[installment.sale_id]) %></td>
        <td class="col-date"><%= format_date(installment.due_date) %></td>
        <td><%= installment_status_badge(installment) %></td>
        <td>
          <%= form_with url: installment_amortizations_path(installment), method: :post, class: "pago-form" do |f| %>
            <div class="pago-inputs">
              <%= f.number_field :amount_usd, step: '0.01', min: '0.01',
                                  placeholder: 'Monto', name: 'amortization[amount_usd]', class: 'pago-monto' %>
            </div>
            <%= f.submit 'Registrar pago' %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @installments.empty? %>
  <p id="no-installments-message">No hay cuotas pendientes.</p>
<% end %>

<div class="table-footer">
  <%= pagination_nav(@pagy) %>
  <%= export_link 'Descargar Excel',
        accounts_receivable_path(request.query_parameters.except('page').merge(format: 'csv')) %>
  <%= export_link 'Descargar PDF',
        accounts_receivable_path(request.query_parameters.except('page').merge(format: 'pdf')) %>
</div>
