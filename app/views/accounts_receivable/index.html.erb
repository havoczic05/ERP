<h1>Cuentas por Cobrar</h1>

<table>
  <thead>
    <tr>
      <th>Cliente</th>
      <th>Venta</th>
      <th>N° de cuota</th>
      <th>Monto (USD)</th>
      <th>Saldo (USD)</th>
      <th>Vencimiento</th>
      <th>Estado</th>
      <th>Pago</th>
    </tr>
  </thead>
  <tbody>
    <% @installments.each do |installment| %>
      <tr id="<%= dom_id(installment) %>">
        <td><%= installment.sale.client.full_name %></td>
        <td><%= installment.sale.correlative %></td>
        <td><%= installment.installment_number %></td>
        <td class="num"><%= number_to_currency(installment.amount_usd, unit: 'USD ') %></td>
        <td class="num"><%= number_to_currency(installment.balance_usd, unit: 'USD ') %></td>
        <td><%= installment.due_date %></td>
        <td><%= installment_status_badge(installment) %></td>
        <td>
          <%= form_with url: installment_amortizations_path(installment), method: :post do |f| %>
            <%= f.number_field :amount_usd, step: '0.01', min: '0.01',
                                placeholder: 'Monto', name: 'amortization[amount_usd]' %>
            <%= f.text_field :notes, placeholder: 'Notas (opcional)',
                              name: 'amortization[notes]' %>
            <%= f.submit 'Registrar pago' %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @installments.empty? %>
  <p id="no-installments-message">No hay cuotas pendientes.</p>
<% end %>

<%== @pagy.series_nav if @pagy.pages > 1 %>
