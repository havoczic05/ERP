<% ranking   = @metrics.top_products %>
<% low_stock = @metrics.low_stock_products.to_a %>
<% upcoming  = @metrics.upcoming_installments.to_a %>
<% peak_count = @metrics.sales_count_by_day.values.max %>
<% peak_total = @metrics.sales_total_by_day.values.max %>

<div class="page-head">
  <h1>Dashboard</h1>
  <p class="page-sub">Resumen del mes en curso y del día de hoy.</p>
</div>

<%# Row 1 — KPI strip. Each tile is a shortcut into its filtered list; the
    month liquidity tiles carry a trend badge vs. the previous month. %>
<section aria-label="Métricas operativas">
  <div class="kpi-grid">
    <%= render "kpi",
        href: sales_path(document_type: "venta", status: "confirmada", date_range: "month"),
        aria_label: "Ver ventas del mes", label: "Ventas del mes",
        value: @metrics.monthly_sales_count,
        meta: number_to_currency(@metrics.monthly_sales_total, unit: "USD "),
        trend: trend_badge(@metrics.monthly_sales_total_trend) %>

    <%= render "kpi",
        href: accounts_receivable_path,
        aria_label: "Ver cobros del mes", label: "Cobrado del mes",
        value: kpi_currency(@metrics.monthly_collected),
        meta: "pagos recibidos este mes",
        trend: trend_badge(@metrics.monthly_collected_trend) %>

    <%= render "kpi",
        href: sales_path(document_type: "venta", status: "confirmada", date_range: "today"),
        aria_label: "Ver ventas de hoy", label: "Ventas de hoy",
        value: @metrics.daily_sales_count,
        meta: number_to_currency(@metrics.daily_sales_total, unit: "USD ") %>

    <%= render "kpi",
        href: accounts_receivable_path(status: "vencida"),
        aria_label: "Ver facturas vencidas", label: "Vencido",
        value: kpi_currency(@metrics.overdue_total),
        meta: pluralize(@metrics.overdue_count, "factura vencida", "facturas vencidas") %>
  </div>
</section>

<%# Row 2 — temporal area charts with a selectable time range %>
<section class="charts" aria-label="Gráficos temporales">
  <div class="charts-head">
    <%= chart_range_toggle(@metrics.chart_range) %>
  </div>

  <div class="chart">
    <h2>Ventas por Día</h2>
    <%= area_chart_svg(@metrics.sales_count_by_day, label: "Cantidad de ventas por día", format: :count, show_values: true) %>
    <p class="chart-caption">Pico del período: <%= peak_count %> ventas en un día</p>
  </div>

  <div class="chart">
    <h2>Monto por Día (USD)</h2>
    <%= area_chart_svg(@metrics.sales_total_by_day, label: "Monto de ventas en USD por día", format: :money) %>
    <p class="chart-caption">Pico del período: <%= number_to_currency(peak_total, unit: 'USD ') %></p>
  </div>
</section>

<%# Row 3 — rankings, alerts & upcoming dues %>
<div class="dash-cols">
  <section class="panel">
    <h2>
      Top 5 Productos del Mes
      <%= link_to "Ver todos", products_path, class: "panel-link" %>
    </h2>
    <% if ranking.any? %>
      <ol class="rank-list">
        <% ranking.each do |product, units| %>
          <li>
            <%= link_to product_path(product), class: "rank-row", data: { turbo_frame: "modal" } do %>
              <span class="rank-name"><%= product.name %></span>
              <span class="rank-val num"><%= units %> u.</span>
            <% end %>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="empty">Sin ventas registradas este mes.</p>
    <% end %>
  </section>

  <section class="panel">
    <h2>
      Bajo Stock
      <% if low_stock.any? %><span class="badge badge--warning"><%= low_stock.size %></span><% end %>
      <%= link_to "Ver todos", products_path, class: "panel-link" %>
    </h2>
    <% if low_stock.any? %>
      <ul class="stock-list">
        <% low_stock.each do |product| %>
          <li>
            <%= link_to product_path(product), class: "stock-row", data: { turbo_frame: "modal" } do %>
              <span><%= product.name %></span>
              <span class="badge badge--warning"><%= product.stock %> u.</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty">Todo el stock está por encima de 10 unidades.</p>
    <% end %>
  </section>

  <section class="panel">
    <h2>
      Vencimientos de la Semana
      <% if upcoming.any? %><span class="badge badge--warning"><%= upcoming.size %></span><% end %>
      <%= link_to "Ver todas", accounts_receivable_path, class: "panel-link" %>
    </h2>
    <% if upcoming.any? %>
      <ul class="stock-list">
        <% upcoming.each do |installment| %>
          <li>
            <%= link_to accounts_receivable_path(q: installment.sale.correlative), class: "stock-row" do %>
              <span><%= installment.sale.client.full_name %> · cuota <%= installment.installment_number %></span>
              <span class="num"><%= format_date(installment.due_date) %> · <%= money(installment.balance_usd) %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty">No hay cuotas por vencer en los próximos 7 días.</p>
    <% end %>
  </section>
</div>

<%= render "shared/modal_frame" %>
