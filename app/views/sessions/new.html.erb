<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.bunny.net">
  <link href="https://fonts.bunny.net/css?family=plus-jakarta-sans:400,500,600,700,800" rel="stylesheet">
  <%= stylesheet_link_tag "login", "data-turbo-track": "reload" %>
<% end %>

<div class="login-page">
  <div class="login-card">
    <div class="login-card__main">
      <section class="login-form">
        <div class="login-brand">
          <svg class="login-brand__mark" viewBox="0 0 32 32" aria-hidden="true">
            <rect width="32" height="32" rx="9" fill="#3838EC"/>
            <text x="16" y="16.5" text-anchor="middle" dominant-baseline="central"
                  font-family="'Plus Jakarta Sans', sans-serif" font-weight="700"
                  font-size="11.5" letter-spacing="-0.5" fill="#ffffff">HGS</text>
          </svg>
          <span class="login-brand__name">HGS ERP</span>
        </div>

        <div class="login-form__body">
          <h1 class="login-title">Bienvenido de nuevo</h1>
          <p class="login-subtitle">Ingresa tu correo y contraseña para acceder a tu cuenta.</p>

          <%= form_with url: session_path, method: :post, class: "login-fields" do |f| %>
            <div class="login-field">
              <%= f.label :email, "Correo electrónico", class: "login-label" %>
              <%= f.email_field :email, autocomplete: "email", required: true,
                    class: "login-input", placeholder: "tucorreo@empresa.com" %>
            </div>

            <div class="login-field">
              <%= f.label :password, "Contraseña", class: "login-label" %>
              <%= f.password_field :password, autocomplete: "current-password", required: true,
                    class: "login-input", placeholder: "••••••••" %>
            </div>

            <%= f.submit "Iniciar sesión", class: "login-submit" %>
          <% end %>
        </div>
      </section>

      <aside class="login-panel">
        <div class="login-panel__copy">
          <h2 class="login-panel__title">Del inventario a la última cuota, todo en un solo lugar.</h2>
          <p class="login-panel__text">Ventas, cobros y stock desde un panel pensado para tu tienda.</p>
        </div>
        <div class="login-panel__visual">
          <%= image_tag "login-brand.webp", alt: "", class: "login-panel__img" %>
        </div>
      </aside>
    </div>

    <footer class="login-card__footer">
      <span>© <%= Date.current.year %> HGS Consulting EIRL.</span>
      <span>Política de privacidad</span>
    </footer>
  </div>
</div>
