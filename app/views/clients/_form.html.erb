<%= form_with model: client, local: false do |f| %>
    <% if client.errors.any? %>
      <div id="error_explanation">
        <h2>No se pudo guardar el cliente. Corrija los siguientes errores:</h2>
        <ul>
          <% client.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="field">
      <%= f.label :full_name, 'Nombre completo' %>
      <%= f.text_field :full_name %>
      <% if client.errors[:full_name].any? %>
        <span class="error"><%= client.errors[:full_name].join(', ') %></span>
      <% end %>
    </div>

    <div class="field-grid">
      <div class="field">
        <%= f.label :document_type, 'Tipo de documento' %>
        <%= f.select :document_type, Client.document_types.keys.map { |k| [k.humanize, k] },
                     { include_blank: 'Seleccionar tipo' } %>
        <% if client.errors[:document_type].any? %>
          <span class="error"><%= client.errors[:document_type].join(', ') %></span>
        <% end %>
      </div>

      <div class="field">
        <%= f.label :document_number, 'Número de documento' %>
        <%= f.text_field :document_number %>
        <% if client.errors[:document_number].any? %>
          <span class="error"><%= client.errors[:document_number].join(', ') %></span>
        <% end %>
      </div>
    </div>

    <div class="field">
      <%= f.label :phone, 'Teléfono' %>
      <%= f.text_field :phone %>
      <% if client.errors[:phone].any? %>
        <span class="error"><%= client.errors[:phone].join(', ') %></span>
      <% end %>
    </div>

    <div class="field">
      <%= f.label :direccion, 'Dirección' %>
      <%= f.text_field :direccion %>
    </div>

    <div class="field-grid">
      <div class="field">
        <%= f.label :distrito, 'Distrito' %>
        <%= f.text_field :distrito %>
      </div>

      <div class="field">
        <%= f.label :provincia, 'Provincia' %>
        <%= f.text_field :provincia %>
      </div>

      <div class="field">
        <%= f.label :departamento, 'Departamento' %>
        <%= f.text_field :departamento %>
      </div>
    </div>

    <div class="form-actions">
      <%= submit_button f, client.persisted? ? 'Actualizar cliente' : 'Crear cliente' %>
      <%= action_link 'Volver a clientes', clients_path, variant: :ghost, size: :md,
                      icon: 'arrow-left', data: { turbo_frame: '_top' } %>
    </div>
  <% end %>
