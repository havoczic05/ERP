<div class="page-head page-head--with-action">
  <h1>Clientes</h1>
  <% if policy(Client).new? %>
    <%= action_link 'Nuevo cliente', new_client_path, variant: :primary, size: :md, icon: :plus,
                    data: { turbo_frame: 'modal' } %>
    <%= action_link 'Nuevo cliente', new_client_path, variant: :primary, icon: :plus,
                    class: "fab", aria: { label: "Nuevo cliente" },
                    data: { turbo_frame: 'modal' } %>
  <% end %>
</div>

<div class="toolbar">
  <%= form_with url: clients_path, method: :get, local: true, class: "filters" do |f| %>
    <%= index_search_field(placeholder: 'Nombre o número de documento') %>

    <%= link_to filters_clients_path(q: params[:q]),
                class: "btn btn--ghost filter-toggle",
                data: { controller: "filter-dialog",
                        action: "click->filter-dialog#load",
                        turbo_frame: "modal", turbo: false },
                aria: { label: "Filtros" } do %>
      <%= icon("filter") %>
      <span>Filtros</span>
    <% end %>

    <div class="field filter-modal-field">
      <%= label_tag :document_type, 'Tipo de documento' %>
      <%= select_tag :document_type,
            options_for_select([['Todos', ''], ['DNI', 'dni'], ['RUC', 'ruc']], params[:document_type]) %>
    </div>

    <%= submit_button f, 'Buscar' %>
    <%= clear_filters_link clients_path %>
  <% end %>
</div>

<div class="table-scroll">
<table class="table-cards">
  <thead>
    <tr>
      <th>Nombre completo</th>
      <th>Tipo de documento</th>
      <th>Número de documento</th>
      <th>Teléfono</th>
      <th>Dirección</th>
      <th>Distrito</th>
      <th>Provincia</th>
      <th>Departamento</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody id="clients">
    <%= render @clients %>
  </tbody>
</table>
</div>

<% if @clients.empty? %>
  <p id="no-clients-message">No se encontraron clientes.</p>
<% end %>

<div class="table-footer">
  <%= pagination_nav(@pagy) %>
  <%= export_link 'Descargar Excel',
        clients_path(request.query_parameters.except('page').merge(format: 'csv')) %>
</div>

<%= render "shared/modal_frame" %>
