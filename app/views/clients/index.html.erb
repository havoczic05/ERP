<div class="page-head"><h1>Clientes</h1></div>

<div class="toolbar">
  <%= form_with url: clients_path, method: :get, local: true, class: "filters" do |f| %>
    <%= search_field placeholder: 'Nombre o número de documento' %>
    <div class="field">
      <%= f.label :document_type, 'Tipo de documento' %>
      <%= select_tag :document_type,
            options_for_select([['Todos', ''], ['DNI', 'dni'], ['RUC', 'ruc']], params[:document_type]) %>
    </div>
    <%= submit_button f, 'Buscar' %>
    <%= clear_filters_link clients_path %>
  <% end %>

  <% if policy(Client).new? %>
    <%= action_link 'Nuevo cliente', new_client_path, variant: :primary, size: :md, icon: :plus,
                    class: "fab", aria: { label: "Nuevo cliente" },
                    data: { turbo_frame: 'modal', controller: 'fab', action: 'fab#click' } %>
  <% end %>
</div>

<table class="table-cards">
  <thead>
    <tr>
      <th>Nombre completo</th>
      <th>Tipo de documento</th>
      <th>Número de documento</th>
      <th>Teléfono</th>
      <th>Dirección</th>
      <th>Distrito</th>
      <th>Provincia</th>
      <th>Departamento</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody id="clients">
    <%= render @clients %>
  </tbody>
</table>

<% if @clients.empty? %>
  <p id="no-clients-message">No se encontraron clientes.</p>
<% end %>

<div class="table-footer">
  <%= pagination_nav(@pagy) %>
  <%= export_link 'Descargar Excel',
        clients_path(request.query_parameters.except('page').merge(format: 'csv')) %>
</div>

<%= render "shared/modal_frame" %>
