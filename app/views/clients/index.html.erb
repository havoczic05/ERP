<h1>Clientes</h1>

<%= form_with url: clients_path, method: :get, local: true do |f| %>
  <%= f.label :q, 'Buscar' %>
  <%= f.text_field :q, value: params[:q], placeholder: 'Nombre o número de documento' %>
  <%= f.submit 'Buscar' %>
<% end %>

<table>
  <thead>
    <tr>
      <th>Nombre completo</th>
      <th>Tipo de documento</th>
      <th>Número de documento</th>
      <th>Teléfono</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <%= render @clients %>
  </tbody>
</table>

<% if @clients.empty? %>
  <p id="no-clients-message">No se encontraron clientes.</p>
<% end %>

<%= action_link 'Nuevo cliente', new_client_path, variant: :primary, size: :md, icon: :plus %>

<%== @pagy.series_nav if @pagy.pages > 1 %>
