<%= turbo_frame_tag "client-picker" do %>
  <% if @clients.empty? %>
    <p>No se encontraron clientes.</p>
  <% else %>
    <ul>
      <% @clients.each do |client| %>
        <li id="<%= dom_id(client) %>">
          <%= client.full_name %> — <%= client.document_type.upcase %> <%= client.document_number %>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>
