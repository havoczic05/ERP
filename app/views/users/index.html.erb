<h1>Usuarios</h1>

<table>
  <thead>
    <tr>
      <th>Correo electrónico</th>
      <th>Rol</th>
      <th>Activo</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr id="<%= dom_id(user) %>">
        <td><%= user.email %></td>
        <td><%= user.role.humanize %></td>
        <td><%= user.active? ? 'Sí' : 'No' %></td>
        <td>
          <%= link_to 'Editar', edit_user_path(user) %>
          <% if user.active? %>
            <%= button_to 'Desactivar', user_path(user), method: :delete,
                          data: { confirm: "¿Desactivar #{user.email}?" } %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @users.empty? %>
  <p id="no-users-message">No se encontraron usuarios.</p>
<% end %>

<%= link_to 'Nuevo usuario', new_user_path %>

<%== @pagy.series_nav if @pagy.pages > 1 %>
