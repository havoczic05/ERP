<h1>Usuarios</h1>

<table>
  <thead>
    <tr>
      <th>Correo electrónico</th>
      <th>Rol</th>
      <th>Activo</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr id="<%= dom_id(user) %>">
        <td><%= user.email %></td>
        <td><%= user.role.humanize %></td>
        <td><%= user.active? ? 'Sí' : 'No' %></td>
        <td class="col-actions">
          <div class="row-actions">
            <%= action_link 'Editar', edit_user_path(user), icon: :pencil %>
            <% if user.active? %>
              <%= action_button 'Desactivar', user_path(user), method: :delete, icon: "user-x",
                                confirm: "¿Desactivar #{user.email}?" %>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @users.empty? %>
  <p id="no-users-message">No se encontraron usuarios.</p>
<% end %>

<%= action_link 'Nuevo usuario', new_user_path, variant: :primary, size: :md, icon: :plus %>

<%== @pagy.series_nav if @pagy.pages > 1 %>
