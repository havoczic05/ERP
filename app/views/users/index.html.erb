<div class="page-head page-head--with-action">
  <div>
    <h1>Usuarios</h1>
    <p class="page-sub">Personas con acceso al sistema.</p>
  </div>
  <%= action_link 'Nuevo usuario', new_user_path, variant: :primary, size: :md, icon: :plus,
                  data: { turbo_frame: 'modal' } %>
</div>

<%= render "shared/settings_nav" %>

<table>
  <thead>
    <tr>
      <th>Correo electrónico</th>
      <th>Rol</th>
      <th>Activo</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody id="users">
    <%= render @users %>
  </tbody>
</table>

<% if @users.empty? %>
  <p id="no-users-message">No se encontraron usuarios.</p>
<% end %>

<%= pagination_nav(@pagy) %>

<%= render "shared/modal_frame" %>
