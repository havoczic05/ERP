<%# Shared upload form for product and client imports.
    Locals:
      action_path  — POST path to submit to
      back_path    — path for "Volver" link
      error        — optional file-level error string (nil when none)
%>
<% error ||= nil %>

<% if error.present? %>
  <div class="flash flash--alert" role="alert">
    <%= error %>
  </div>
<% end %>

<%= form_with url: action_path, method: :post,
              multipart: true,
              data: { turbo: true } do |f| %>
  <div class="field">
    <label for="file">Archivo</label>
    <input type="file" name="file" id="file" accept=".csv,.xlsx" required>
    <p class="field-hint">Formatos: CSV, XLSX &middot; máx 500 filas</p>
  </div>

  <div class="form-actions">
    <%= submit_button f, "Importar", size: :md %>
    <%= action_link "Volver a configuración", company_settings_path,
                    variant: :ghost, size: :md, icon: "arrow-left" %>
  </div>
<% end %>

<div id="import_results">
  <% if local_assigns[:report].present? %>
    <%= render "imports/report", report: report %>
  <% end %>
</div>
