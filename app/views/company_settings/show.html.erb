<div class="page-head page-head--with-action">
  <div>
    <h1>Configuración</h1>
    <p class="page-sub">Ajustes del negocio y de la cuenta</p>
  </div>
  <%= action_link "Editar configuración", edit_company_settings_path,
                  variant: :primary, size: :md, icon: :pencil, class: "fab",
                  aria: { label: "Editar configuración" },
                  data: { turbo_frame: "modal", controller: "fab", action: "fab#click" } %>
</div>

<%= render "shared/settings_nav" %>

<%= render "details", company_settings: @company_settings, warehouses: @warehouses %>

<%= render "shared/modal_frame" %>
