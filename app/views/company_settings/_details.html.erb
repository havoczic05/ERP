<div id="company_settings">
  <h2>Datos de la empresa</h2>
  <dl>
    <dt>Razón social</dt>
    <dd><%= company_settings.razon_social %></dd>

    <% if company_settings.subtitulo.present? %>
      <dt>Subtítulo</dt>
      <dd><%= company_settings.subtitulo %></dd>
    <% end %>

    <dt>RUC</dt>
    <dd><%= company_settings.ruc %></dd>

    <dt>Dirección</dt>
    <dd><%= company_settings.direccion %></dd>

    <dt>Teléfono</dt>
    <dd><%= company_settings.telefono %></dd>

    <% if company_settings.logo.attached? %>
      <dt>Logo</dt>
      <dd><%= image_tag company_settings.logo, alt: "Logo de la empresa" %></dd>
    <% end %>
  </dl>

  <% if company_settings.bank_accounts.any? %>
    <h2>Cuentas bancarias</h2>
    <ul class="bank-accounts-list">
      <% company_settings.bank_accounts.each do |account| %>
        <li>
          <strong><%= account.bank %><%= " — #{account.currency_label}" if account.currency_label.present? %></strong>
          <% if account.account_number.present? %>
            <span>CTA. CTE.: <%= account.account_number %></span>
          <% end %>
          <% if account.interbank_number.present? %>
            <span>CTA. INTERBANCARIO: <%= account.interbank_number %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <div class="action-bar">
    <%= action_link "Editar configuración", edit_company_settings_path,
                    variant: :primary, size: :md, icon: :pencil, data: { turbo_frame: "modal" } %>
  </div>
</div>
