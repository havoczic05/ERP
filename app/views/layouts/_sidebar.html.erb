<%# Mobile top bar (≤640px): hamburger toggle + brand. Hidden on desktop. %>
<div class="app-topbar">
  <button type="button" class="nav-toggle" data-action="nav#toggle" data-nav-target="toggle"
          aria-controls="app-drawer" aria-expanded="false" aria-label="Abrir menú">
    <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="4" y1="7" x2="20" y2="7"/>
      <line x1="4" y1="12" x2="20" y2="12"/>
      <line x1="4" y1="17" x2="20" y2="17"/>
    </svg>
  </button>
  <%= link_to "HGS ERP", root_path, class: "app-topbar__brand" %>
</div>

<aside id="app-drawer" class="app-sidebar" data-nav-target="drawer">

  <button type="button" class="sidebar-toggle" data-action="sidebar#toggle"
          aria-label="Colapsar menú" title="Colapsar menú">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m15 18-6-6 6-6"/>
    </svg>
  </button>

  <%= link_to root_path, class: "sidebar-brand" do %>
    <svg class="sidebar-brand__mark" viewBox="0 0 32 32" aria-hidden="true">
      <rect width="32" height="32" rx="9" fill="currentColor"/>
      <text x="16" y="16.5" text-anchor="middle" dominant-baseline="central"
            font-family="'Plus Jakarta Sans', sans-serif" font-weight="700"
            font-size="11.5" letter-spacing="-0.5" fill="#ffffff">HGS</text>
    </svg>
    <span class="sidebar-brand__name">HGS ERP</span>
  <% end %>

  <nav class="sidebar-nav" aria-label="Primary">
    <div class="nav-group">
      <p class="nav-group-label">Operaciones</p>
      <%= nav_link_to "Ventas", sales_path, controllers: "sales", icon: :receipt if policy(Sale).index? %>
      <%= nav_link_to "Clientes", clients_path, controllers: "clients", icon: :users if policy(Client).index? %>
      <%= nav_link_to "Productos", products_path, controllers: "products", icon: :package if policy(Product).index? %>
      <%= nav_link_to "Cuentas por Cobrar", accounts_receivable_path, controllers: "accounts_receivable", icon: :wallet if policy(Amortization).index? %>
    </div>

    <% if current_user.admin? %>
      <div class="nav-group">
        <p class="nav-group-label">Administración</p>
        <%= nav_link_to "Dashboard", dashboard_path, controllers: "dashboards", icon: "layout-grid" if policy(:dashboard).show? %>
        <%# Almacenes y Usuarios viven dentro de Configuración (ajustes del negocio) %>
        <%= nav_link_to "Configuración", company_settings_path,
                        controllers: %w[company_settings warehouses users], icon: :settings %>
      </div>
    <% end %>
  </nav>

  <div class="sidebar-foot">
    <div class="sidebar-user">
      <span class="sidebar-avatar" aria-hidden="true"><%= current_user.email.first.upcase %></span>
      <div class="sidebar-user__info">
        <span class="sidebar-user-email"><%= current_user.email %></span>
        <span class="sidebar-user-role"><%= current_user.role.humanize %></span>
      </div>
    </div>
    <%= button_to logout_path, method: :delete, class: "btn--ghost btn--block sidebar-logout" do %>
      <%= icon("log-out") %>
      <span class="sidebar-logout__label">Cerrar sesión</span>
    <% end %>
  </div>
</aside>
