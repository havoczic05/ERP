<h1>Nuevo documento de venta</h1>

<% if @errors.present? %>
  <div id="sale-errors" class="flash-alert">
    <ul>
      <% @errors.each do |error| %>
        <li><%= error %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%# Stimulus sale-form controller scope.
    The data-controller wrapper must enclose BOTH the client-search input and
    the line-items section because the controller handles actions on both. %>
<div data-controller="sale-form"
     data-sale-form-search-url-value="<%= search_clients_path %>">
<%= form_with url: sales_path, method: :post do |f| %>
  <section class="form-section">
    <h2>Documento</h2>

    <%# Client picker — reusable combobox. On select, sale-form#clientSelected
        reveals the selected client's document + an edit link (new tab). %>
    <%= combobox label: 'Buscar cliente', query_name: :q,
          hidden_name: 'sale[client_id]', hidden_value: @sale.client_id,
          search_path: search_clients_path,
          placeholder: 'Nombre o número de documento', wrapper_class: 'client-search',
          select_action: 'combobox:select->sale-form#clientSelected' do %>
      <div class="client-meta" data-sale-form-target="clientMeta" hidden>
        <span class="client-doc" data-sale-form-target="clientDoc"></span>
        <%= link_to "#", target: "_blank", rel: "noopener",
              class: "btn btn--ghost btn--sm", title: "Editar cliente",
              data: { "sale-form-target": "clientEdit" } do %>
          <%= icon(:pencil) %>
        <% end %>
      </div>
    <% end %>

    <%# Warehouse is preset (single default almacén); carried as a hidden field. %>
    <%= hidden_field_tag 'sale[warehouse_id]', @sale.warehouse_id %>

    <div class="field-grid field-grid--4">
      <div class="field">
        <%= label_tag 'sale[document_type]', 'Tipo de documento' %>
        <%= select_tag 'sale[document_type]',
            options_for_select([['Cotización', 'cotizacion'], ['Venta', 'venta']],
                               @sale.document_type) %>
      </div>

      <%# Payment mode is UI-only (Sale has no payment column): Contado disables
          the installment fields (so they submit nothing → service defaults to a
          single installment); Cuotas enables them. %>
      <fieldset class="field payment-mode">
        <legend>Forma de pago</legend>
        <div class="payment-options">
          <label><%= radio_button_tag 'payment_method', 'contado', true,
                       data: { action: 'change->sale-form#togglePaymentMode' } %> Contado</label>
          <label><%= radio_button_tag 'payment_method', 'cuotas', false,
                       data: { action: 'change->sale-form#togglePaymentMode' } %> Cuotas</label>
        </div>
      </fieldset>

      <div class="field">
        <%= label_tag 'sale[num_installments]', 'Número de cuotas' %>
        <%= number_field_tag 'sale[num_installments]', 1, min: 1, max: 4, disabled: true,
            data: { 'sale-form-target': 'numInstallments' } %>
      </div>

      <div class="field">
        <%= label_tag 'sale[interval_days]', 'Intervalo (días)' %>
        <%= select_tag 'sale[interval_days]',
            options_for_select([7, 10, 15, 30, 45].map { |d| [d.to_s, d] }, 30),
            disabled: true,
            data: { 'sale-form-target': 'intervalDays' } %>
      </div>
    </div>

    <div class="field field--full">
      <%= label_tag 'sale[notes]', 'Notas' %>
      <%= text_area_tag 'sale[notes]', @sale.notes %>
    </div>
  </section>

  <%# Line items — Stimulus sale-form controller manages add/remove rows
      and computes line totals client-side. %>
  <section class="form-section" id="line-items">
    <h3>Líneas de producto</h3>

    <table id="line-items-table" class="line-items-table">
      <thead>
        <tr>
          <th>Producto</th>
          <th class="num">Cantidad</th>
          <th class="num">Precio unitario (USD)</th>
          <th class="num">Subtotal (USD)</th>
          <th></th>
        </tr>
      </thead>
      <tbody data-sale-form-target="lineItemsBody">
        <tr class="line-item">
          <td><%= combobox query_name: 'sale[items][][product_query]',
                    hidden_name: 'sale[items][][product_id]',
                    search_path: search_products_path,
                    placeholder: 'Escriba el nombre del producto',
                    wrapper_class: 'product-search',
                    select_action: 'combobox:select->sale-form#productSelected' %></td>
          <td><%= number_field_tag 'sale[items][][quantity]', 1, min: 1,
                  data: { 'sale-form-target': 'quantity',
                          action: 'input->sale-form#recompute' } %></td>
          <td><%= number_field_tag 'sale[items][][unit_price_usd]', '0.00', step: '0.01',
                  data: { 'sale-form-target': 'unitPrice',
                          action: 'input->sale-form#recompute' } %></td>
          <td class="col-total" data-sale-form-target="lineTotal">USD 0.00</td>
          <td><button type="button" class="btn--ghost btn--sm" data-action="sale-form#removeLine">Eliminar</button></td>
        </tr>
      </tbody>
    </table>

    <button type="button" class="btn--ghost btn--sm" data-action="sale-form#addLine">Agregar línea</button>

    <div class="totals-bar">
      <span class="totals-label">Total general (USD)</span>
      <span class="totals-value" data-sale-form-target="grandTotal">0.00</span>
    </div>
  </section>

  <div class="action-bar">
    <%= f.submit 'Crear documento' %>
    <%= link_to 'Volver a ventas', sales_path %>
  </div>
<% end %>
</div>
