<div class="toolbar">
  <div class="page-head">
    <h1>Ventas</h1>
    <p class="page-sub"><%= pluralize(@pagy.count, 'documento') %></p>
  </div>
  <%= link_to 'Nuevo documento', new_sale_path, class: 'btn' %>
</div>

<% if @sales.any? %>
  <table>
    <thead>
      <tr>
        <th>Correlativo</th>
        <th>Tipo</th>
        <th>Cliente</th>
        <th class="num">Total (USD)</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @sales.each do |sale| %>
        <tr id="<%= dom_id(sale) %>">
          <td><%= sale.correlative %></td>
          <td><%= document_type_label(sale.document_type) %></td>
          <td><%= sale.client.full_name %></td>
          <td class="num"><%= number_to_currency(sale.total_usd, unit: 'USD ') %></td>
          <td><%= sale_status_badge(sale) %></td>
          <td>
            <div class="row-actions">
              <%= link_to 'Ver', sale %>
              <% if policy(sale).annul? && sale.confirmada? && sale.venta? %>
                <%= button_to 'Anular', annul_sale_path(sale), method: :post,
                              class: 'btn--danger btn--sm',
                              data: { confirm: '¿Anular esta venta? Esta acción no se puede deshacer.' } %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%== @pagy.series_nav if @pagy.pages > 1 %>
<% else %>
  <div class="empty-state">
    <p id="no-sales-message">No se encontraron ventas.</p>
    <%= link_to 'Nuevo documento', new_sale_path, class: 'btn' %>
  </div>
<% end %>
