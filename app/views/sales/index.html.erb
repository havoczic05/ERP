<div class="toolbar">
  <div class="page-head">
    <h1>Sales</h1>
    <p class="page-sub"><%= pluralize(@pagy.count, 'document') %></p>
  </div>
  <%= link_to 'New Document', new_sale_path, class: 'btn' %>
</div>

<% if @sales.any? %>
  <table>
    <thead>
      <tr>
        <th>Correlative</th>
        <th>Type</th>
        <th>Client</th>
        <th class="num">Total (USD)</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @sales.each do |sale| %>
        <tr id="<%= dom_id(sale) %>">
          <td><%= sale.correlative %></td>
          <td><%= sale.document_type.humanize %></td>
          <td><%= sale.client.full_name %></td>
          <td class="num"><%= number_to_currency(sale.total_usd, unit: 'USD ') %></td>
          <td><%= sale_status_badge(sale) %></td>
          <td>
            <div class="row-actions">
              <%= link_to 'View', sale %>
              <% if policy(sale).annul? && sale.confirmada? && sale.venta? %>
                <%= button_to 'Annul', annul_sale_path(sale), method: :post,
                              class: 'btn--danger btn--sm',
                              data: { confirm: 'Annul this sale? This cannot be undone.' } %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%== @pagy.series_nav if @pagy.pages > 1 %>
<% else %>
  <div class="empty-state">
    <p id="no-sales-message">No sales found.</p>
    <%= link_to 'New Document', new_sale_path, class: 'btn' %>
  </div>
<% end %>
