<div class="page-head page-head--with-action">
  <h1>Ventas</h1>
  <%= action_link 'Nuevo documento', new_sale_path, variant: :primary, size: :md, icon: :plus,
                  class: "fab", aria: { label: "Nuevo documento" },
                  data: { controller: "fab", action: "fab#click" } %>
</div>

<div class="toolbar">
  <%= form_with url: sales_path, method: :get, class: "filters" do |f| %>
    <%= index_search_field(placeholder: 'Cliente o correlativo') %>

    <%= link_to filters_sales_path(request.query_parameters),
                class: "btn btn--ghost filter-toggle",
                data: { turbo_frame: "modal" },
                aria: { label: "Filtros" } do %>
      <%= icon("filter") %>
      <span>Filtros</span>
    <% end %>

    <div class="field filter-modal-field">
      <%= label_tag :date_range, 'Fecha' %>
      <%= select_tag :date_range, options_for_select(DateRange::OPTIONS, params[:date_range]) %>
    </div>
    <div class="field filter-modal-field">
      <%= label_tag :on, 'Día específico' %>
      <%= date_field_tag :on, params[:on] %>
    </div>
    <div class="field filter-modal-field">
      <%= label_tag :document_type, 'Tipo' %>
      <%= select_tag :document_type,
            options_for_select([['Todos', ''], ['Cotización', 'cotizacion'], ['Venta', 'venta']],
                               params[:document_type]) %>
    </div>
    <div class="field filter-modal-field">
      <%= label_tag :status, 'Estado' %>
      <%= select_tag :status,
            options_for_select([['Todos', ''], ['Confirmada', 'confirmada'], ['Anulada', 'anulada']],
                               params[:status]) %>
    </div>

    <%= submit_button f, 'Buscar' %>
    <%= clear_filters_link sales_path %>
  <% end %>
</div>

<%= render "shared/modal_frame" %>

<% if @sales.any? %>
  <div class="table-scroll">
  <table class="table-cards">
    <thead>
      <tr>
        <th>Correlativo</th>
        <th><%= sortable_date_header 'Fecha' %></th>
        <th>Tipo</th>
        <th>Cliente</th>
        <th class="num">Total (USD)</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @sales.each do |sale| %>
        <tr id="<%= dom_id(sale) %>">
          <td data-label="Correlativo"><%= sale.correlative %></td>
          <td class="col-date" data-label="Fecha"><%= format_date(sale.created_at) %></td>
          <td data-label="Tipo"><%= document_type_label(sale.document_type) %></td>
          <td data-label="Cliente"><%= sale.client.full_name %></td>
          <td data-label="Total (USD)"><%= money(sale.total_usd) %></td>
          <td data-label="Estado"><%= sale_status_badge(sale) %></td>
          <td class="col-actions">
            <%= render layout: "shared/actions_menu" do %>
              <%= action_link 'Ver', sale, icon: :eye %>
              <% if policy(sale).annul? && sale.confirmada? && sale.venta? %>
                <%= action_button 'Anular', annul_sale_path(sale), method: :post, icon: :ban,
                                  confirm: '¿Anular esta venta? Esta acción no se puede deshacer.' %>
              <% end %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>

  <div class="table-footer">
    <%= pagination_nav(@pagy) %>
    <p class="footer-subtotal">
      Subtotal: <strong><%= number_to_currency(@subtotal, unit: 'USD ') %></strong>
    </p>
    <%= export_link 'Descargar Excel',
          sales_path(request.query_parameters.except('page').merge(format: 'csv')) %>
  </div>
<% else %>
  <div class="empty-state">
    <p id="no-sales-message">No se encontraron ventas.</p>
    <%= action_link 'Nuevo documento', new_sale_path, variant: :primary, size: :md, icon: :plus %>
  </div>
<% end %>
