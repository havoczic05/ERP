<div class="page-head">
  <h1>Ventas</h1>
</div>

<div class="toolbar">
  <%= form_with url: sales_path, method: :get, class: "filters" do |f| %>
    <%= search_field placeholder: 'Cliente o correlativo' %>
    <div class="field">
      <%= label_tag :date_range, 'Fecha' %>
      <%= select_tag :date_range, options_for_select(DateRange::OPTIONS, params[:date_range]) %>
    </div>
    <div class="field">
      <%= label_tag :on, 'Día específico' %>
      <%= date_field_tag :on, params[:on] %>
    </div>
    <div class="field">
      <%= label_tag :document_type, 'Tipo' %>
      <%= select_tag :document_type,
            options_for_select([['Todos', ''], ['Cotización', 'cotizacion'], ['Venta', 'venta']],
                               params[:document_type]) %>
    </div>
    <div class="field">
      <%= label_tag :status, 'Estado' %>
      <%= select_tag :status,
            options_for_select([['Todos', ''], ['Confirmada', 'confirmada'], ['Anulada', 'anulada']],
                               params[:status]) %>
    </div>
    <%= f.submit 'Buscar' %>
    <%= clear_filters_link sales_path %>
  <% end %>

  <%= action_link 'Nuevo documento', new_sale_path, variant: :primary, size: :md, icon: :plus %>
</div>

<% if @sales.any? %>
  <table>
    <thead>
      <tr>
        <th>Correlativo</th>
        <th><%= sortable_date_header 'Fecha' %></th>
        <th>Tipo</th>
        <th>Cliente</th>
        <th class="num">Total (USD)</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @sales.each do |sale| %>
        <tr id="<%= dom_id(sale) %>">
          <td><%= sale.correlative %></td>
          <td class="col-date"><%= format_date(sale.created_at) %></td>
          <td><%= document_type_label(sale.document_type) %></td>
          <td><%= sale.client.full_name %></td>
          <td><%= money(sale.total_usd) %></td>
          <td><%= sale_status_badge(sale) %></td>
          <td class="col-actions">
            <div class="row-actions">
              <%= action_link 'Ver', sale, icon: :eye %>
              <% if policy(sale).annul? && sale.confirmada? && sale.venta? %>
                <%= action_button 'Anular', annul_sale_path(sale), method: :post, icon: :ban,
                                  confirm: '¿Anular esta venta? Esta acción no se puede deshacer.' %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="table-footer">
    <%= pagination_nav(@pagy) %>
    <p class="footer-subtotal">
      Subtotal: <strong><%= number_to_currency(@subtotal, unit: 'USD ') %></strong>
    </p>
    <%= export_link 'Descargar Excel',
          sales_path(request.query_parameters.except('page').merge(format: 'csv')) %>
  </div>
<% else %>
  <div class="empty-state">
    <p id="no-sales-message">No se encontraron ventas.</p>
    <%= action_link 'Nuevo documento', new_sale_path, variant: :primary, size: :md, icon: :plus %>
  </div>
<% end %>
