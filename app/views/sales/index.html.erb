<h1>Sales</h1>

<%= link_to 'New Document', new_sale_path %>

<table>
  <thead>
    <tr>
      <th>Correlative</th>
      <th>Type</th>
      <th>Client</th>
      <th>Total (USD)</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @sales.each do |sale| %>
      <tr>
        <td><%= sale.correlative %></td>
        <td><%= sale.document_type.humanize %></td>
        <td><%= sale.client.full_name %></td>
        <td><%= number_to_currency(sale.total_usd, unit: 'USD ') %></td>
        <td><%= sale.status.humanize %></td>
        <td>
          <%= link_to 'View', sale %>
          <% if policy(sale).annul? && sale.confirmada? && sale.venta? %>
            <%= button_to 'Annul', annul_sale_path(sale), method: :post,
                          data: { confirm: 'Annul this sale? This cannot be undone.' } %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @sales.empty? %>
  <p>No sales found.</p>
<% end %>

<%== @pagy.series_nav if @pagy.pages > 1 %>
