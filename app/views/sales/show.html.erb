<div class="detail-head">
  <h1>Sale <%= @sale.correlative %></h1>
  <%= sale_status_badge(@sale) %>
</div>
<p class="detail-meta">
  <%= document_type_label(@sale.document_type) %> · <%= @sale.client.full_name %> · <%= @sale.warehouse.name %>
</p>

<dl>
  <dt>Subtotal</dt>
  <dd><%= number_to_currency(@sale.subtotal_usd, unit: 'USD ') %></dd>

  <dt>Impuesto</dt>
  <dd><%= number_to_currency(@sale.tax_usd, unit: 'USD ') %></dd>

  <dt>Total</dt>
  <dd><%= number_to_currency(@sale.total_usd, unit: 'USD ') %></dd>

  <% if @sale.notes.present? %>
    <dt>Notas</dt>
    <dd><%= @sale.notes %></dd>
  <% end %>
</dl>

<h2>Líneas de producto</h2>
<table>
  <thead>
    <tr>
      <th>Producto</th>
      <th class="num">Cant.</th>
      <th class="num">Precio unitario</th>
      <th class="num">Subtotal</th>
    </tr>
  </thead>
  <tbody>
    <% @sale.sale_items.each do |item| %>
      <tr>
        <td><%= item.product.name %></td>
        <td class="num"><%= item.quantity %></td>
        <td><%= money(item.unit_price_usd) %></td>
        <td><%= money(item.line_total_usd) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @sale.installments.any? %>
  <h2>Cuotas</h2>
  <table>
    <thead>
      <tr>
        <th class="num">#</th>
        <th class="num">Monto</th>
        <th class="num">Saldo</th>
        <th>Fecha de vencimiento</th>
        <th>Estado</th>
      </tr>
    </thead>
    <tbody>
      <% @sale.installments.order(:installment_number).each do |inst| %>
        <tr>
          <td class="num"><%= inst.installment_number %></td>
          <td><%= money(inst.amount_usd) %></td>
          <td><%= money(inst.balance_usd) %></td>
          <td class="col-date"><%= format_date(inst.due_date) %></td>
          <td><%= installment_status_badge(inst) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<% if @amortizations.any? %>
  <h2>Historial de pagos</h2>
  <table>
    <thead>
      <tr>
        <th class="num">Cuota</th>
        <th>Fecha de pago</th>
        <th class="num">Monto</th>
      </tr>
    </thead>
    <tbody>
      <% @amortizations.each do |amort| %>
        <tr>
          <td class="num"><%= amort.installment.installment_number %></td>
          <td class="col-date"><%= format_date(amort.paid_at) %></td>
          <td><%= money(amort.amount_usd) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<% if @sale.credit_note %>
  <h2>Nota de crédito</h2>
  <p class="note-card">
    Emitida: <%= format_date(@sale.credit_note.issued_at) %> —
    Total: <%= number_to_currency(@sale.credit_note.total_usd, unit: 'USD ') %>
  </p>
<% end %>

<div class="action-bar">
  <% if @sale.cotizacion? && @sale.confirmada? && policy(@sale).convert_to_sale? %>
    <%= action_link 'Convertir a venta', convert_sale_path(@sale),
                    variant: :primary, size: :md, icon: :plus %>
  <% end %>

  <% if policy(@sale).annul? && @sale.confirmada? && @sale.venta? %>
    <%= action_button 'Anular venta', annul_sale_path(@sale), method: :post,
                      variant: :danger, size: :md, icon: :ban,
                      confirm: '¿Anular esta venta? Esta acción no se puede deshacer.' %>
  <% end %>

  <span class="spacer"></span>
  <%= action_link 'Descargar PDF', sale_path(@sale, format: :pdf), size: :md, icon: :download,
                  target: "_blank", rel: "noopener" %>
  <% if @sale.installments.any? %>
    <%= action_link 'Descargar PDF sin cuotas', sale_path(@sale, format: :pdf, cuotas: false),
                    size: :md, icon: :download, target: "_blank", rel: "noopener" %>
  <% end %>
  <%= action_link 'Volver a ventas', sales_path, size: :md, icon: "arrow-left" %>
</div>
