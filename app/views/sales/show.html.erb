<% if flash[:notice].present? %>
  <div id="notice"><%= flash[:notice] %></div>
<% end %>

<% if flash[:alert].present? %>
  <div id="alert"><%= flash[:alert] %></div>
<% end %>

<h1>Sale <%= @sale.correlative %></h1>

<dl>
  <dt>Document Type</dt>
  <dd><%= @sale.document_type.humanize %></dd>

  <dt>Status</dt>
  <dd><%= sale_status_badge(@sale) %></dd>

  <dt>Client</dt>
  <dd><%= @sale.client.full_name %></dd>

  <dt>Warehouse</dt>
  <dd><%= @sale.warehouse.name %></dd>

  <dt>Subtotal</dt>
  <dd class="num"><%= number_to_currency(@sale.subtotal_usd, unit: 'USD ') %></dd>

  <dt>Tax</dt>
  <dd class="num"><%= number_to_currency(@sale.tax_usd, unit: 'USD ') %></dd>

  <dt>Total</dt>
  <dd class="num"><%= number_to_currency(@sale.total_usd, unit: 'USD ') %></dd>

  <% if @sale.notes.present? %>
    <dt>Notes</dt>
    <dd><%= @sale.notes %></dd>
  <% end %>
</dl>

<h2>Line Items</h2>
<table>
  <thead>
    <tr>
      <th>Product</th>
      <th>Qty</th>
      <th>Unit Price</th>
      <th>Line Total</th>
    </tr>
  </thead>
  <tbody>
    <% @sale.sale_items.each do |item| %>
      <tr>
        <td><%= item.product.name %></td>
        <td><%= item.quantity %></td>
        <td class="num"><%= number_to_currency(item.unit_price_usd, unit: 'USD ') %></td>
        <td class="num"><%= number_to_currency(item.line_total_usd, unit: 'USD ') %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @sale.installments.any? %>
  <h2>Installments</h2>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Amount</th>
        <th>Balance</th>
        <th>Due Date</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @sale.installments.order(:installment_number).each do |inst| %>
        <tr>
          <td><%= inst.installment_number %></td>
          <td class="num"><%= number_to_currency(inst.amount_usd, unit: 'USD ') %></td>
          <td class="num"><%= number_to_currency(inst.balance_usd, unit: 'USD ') %></td>
          <td><%= inst.due_date %></td>
          <td><%= installment_status_badge(inst) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<% if @sale.credit_note %>
  <h2>Credit Note</h2>
  <p>
    Issued: <%= @sale.credit_note.issued_at %> —
    Total: <%= number_to_currency(@sale.credit_note.total_usd, unit: 'USD ') %>
  </p>
<% end %>

<div>
  <% if @sale.cotizacion? && @sale.confirmada? && policy(@sale).convert_to_sale? %>
    <%= button_to 'Convert to Venta', convert_to_sale_sale_path(@sale), method: :post,
                  params: { num_installments: 1, interval_days: 30 } %>
  <% end %>

  <% if policy(@sale).annul? && @sale.confirmada? && @sale.venta? %>
    <%= button_to 'Annul Sale', annul_sale_path(@sale), method: :post,
                  data: { confirm: 'Annul this sale? This cannot be undone.' } %>
  <% end %>
</div>

<%= link_to 'Descargar PDF', sale_path(@sale, format: :pdf) %>
<%= link_to 'Back to Sales', sales_path %>
