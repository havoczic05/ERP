<div class="page-head page-head--with-action">
  <h1>Productos</h1>
  <% if policy(Product).new? %>
    <%= action_link 'Nuevo producto', new_product_path, variant: :primary, size: :md, icon: :plus,
                    data: { turbo_frame: 'modal' } %>
    <%= action_link 'Nuevo producto', new_product_path, variant: :primary, icon: :plus,
                    class: "fab",
                    data: { turbo_frame: 'modal' } %>
  <% end %>
</div>

<div class="toolbar">
  <%= form_with url: products_path, method: :get, local: true, class: "filters" do |f| %>
    <%= index_search_field placeholder: 'Nombre o SKU' %>

    <div class="field">
      <label for="warehouse_id">Almacén</label>
      <select id="warehouse_id" name="warehouse_id">
        <option value="">Todos los almacenes</option>
        <% @warehouses.each do |wh| %>
          <option value="<%= wh.id %>" <%= 'selected' if params[:warehouse_id].to_s == wh.id.to_s %>>
            <%= wh.name %>
          </option>
        <% end %>
      </select>
    </div>

    <%= submit_button f, 'Buscar' %>
    <%= clear_filters_link products_path %>
  <% end %>
</div>

<div class="table-scroll">
<table class="table-cards">
  <thead>
    <tr>
      <th>SKU</th>
      <th>Nombre</th>
      <th>Marca</th>
      <th>Almacén</th>
      <th>Stock</th>
      <th class="num">Precio base (USD)</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody id="products">
    <%= render @products %>
  </tbody>
</table>
</div>

<% if @products.empty? %>
  <p id="no-products-message">No se encontraron productos</p>
<% end %>

<div class="table-footer">
  <%= pagination_nav(@pagy) %>
  <%= export_link 'Descargar Excel',
        products_path(request.query_parameters.except('page').merge(format: 'csv')) %>
</div>

<%= render "shared/modal_frame" %>
