<div class="page-head"><h1>Productos</h1></div>

<div class="toolbar">
  <form action="<%= products_path %>" method="get" class="filters">
    <div class="field">
      <label for="q">Buscar (nombre o SKU)</label>
      <input type="text" id="q" name="q" value="<%= params[:q] %>">
    </div>

    <div class="field">
      <label for="warehouse_id">Almacén</label>
      <select id="warehouse_id" name="warehouse_id">
        <option value="">Todos los almacenes</option>
        <% @warehouses.each do |wh| %>
          <option value="<%= wh.id %>" <%= 'selected' if params[:warehouse_id].to_s == wh.id.to_s %>>
            <%= wh.name %>
          </option>
        <% end %>
      </select>
    </div>

    <button type="submit">Buscar</button>
  </form>

  <%= action_link 'Nuevo producto', new_product_path, variant: :primary, size: :md, icon: :plus %>
</div>

<table>
  <thead>
    <tr>
      <th>SKU</th>
      <th>Nombre</th>
      <th>Marca</th>
      <th>Almacén</th>
      <th>Stock</th>
      <th>Precio base USD</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <%= render @products %>
  </tbody>
</table>

<% if @products.empty? %>
  <p id="no-products-message">No se encontraron productos</p>
<% end %>

<%= pagination_nav(@pagy) %>
