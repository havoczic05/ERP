<%= render layout: "shared/modal", locals: { title: "Detalle del producto" } do %>
  <dl class="modal-details">
    <dt>SKU</dt>
    <dd><%= @product.sku %></dd>

    <dt>Nombre</dt>
    <dd><%= @product.name %></dd>

    <dt>Marca</dt>
    <dd><%= @product.brand %></dd>

    <dt>Almacén</dt>
    <dd><%= @product.warehouse&.name %></dd>

    <dt>Stock</dt>
    <dd><%= @product.stock %></dd>

    <dt>Precio base USD</dt>
    <dd><%= number_to_currency(@product.base_price_usd, unit: 'USD ') %></dd>
  </dl>

  <div class="form-actions">
    <% if policy(@product).edit? %>
      <%= action_link 'Editar', edit_product_path(@product), variant: :primary, size: :md, icon: :pencil,
                      data: { turbo_frame: 'modal' } %>
    <% end %>
    <%= action_link 'Volver a productos', products_path, variant: :ghost, size: :md,
                    icon: 'arrow-left', data: { turbo_frame: '_top' } %>
  </div>
<% end %>
